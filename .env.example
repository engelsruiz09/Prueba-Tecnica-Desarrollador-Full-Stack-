# ============================================
# PostgreSQL
# ============================================
POSTGRES_USER=vantum_user
POSTGRES_PASSWORD=vantum_dev_password
POSTGRES_DB=vantum_db
POSTGRES_PORT=5432

# ============================================
# Backend (FastAPI)
# ============================================
# Nota: el host 'db' hace referencia al nombre del servicio en docker-compose,
# no a localhost. Dentro de la red de Docker, los contenedores se ven por nombre.
DATABASE_URL=postgresql+asyncpg://vantum_user:vantum_dev_password@db:5432/vantum_db
BACKEND_PORT=8000

# Clave para firmar JWT. En producción debe generarse con:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change_me_in_production_use_a_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# Origen permitido para CORS (frontend)
CORS_ORIGINS=http://localhost:5173

# ============================================
# Frontend (React + Vite)
# ============================================
FRONTEND_PORT=5173
# VITE_ prefix es obligatorio para que Vite exponga la variable al navegador
VITE_API_BASE_URL=http://localhost:8000/api/v1